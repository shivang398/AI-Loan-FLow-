# ─────────────────────────────────────────────────────────────────────────────
# Realmoney Advisory Platform — Backend Environment
# Copy to .env and fill in ALL required values before starting.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS_openssl_rand_-hex_32
JWT_EXPIRY_MS=900000

# ── MySQL databases (one per service domain) ─────────────────────────────────
# In production: host = RDS endpoint, port = 3306
# In local dev:  host = localhost,     port = 3307 (docker-compose maps 3307→3306)
AUTH_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_auth"
LOAN_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_loan_core"
CUSTOMER_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_customer_docs"
SALESOPS_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_sales_ops"
COMMS_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_communications"
ANALYTICS_DATABASE_URL="mysql://root:REPLACE_DB_PASSWORD@YOUR_RDS_ENDPOINT:3306/platform_analytics_reporting"

# ── Redis ────────────────────────────────────────────────────────────────────
# Docker service name in prod compose, localhost in local dev
REDIS_HOST=redis
REDIS_PORT=6379

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# Docker service name in prod compose; must match RABBITMQ_USER/PASS in platform/.env
RABBITMQ_URL=amqp://REPLACE_RABBITMQ_USER:REPLACE_RABBITMQ_PASS@rabbitmq:5672
RABBITMQ_EXCHANGE=platform.exchange

# ── AWS S3 ───────────────────────────────────────────────────────────────────
# Use a least-privilege IAM user scoped to this bucket only (s3:PutObject, s3:GetObject, s3:DeleteObject)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_IAM_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_IAM_SECRET_KEY
AWS_S3_BUCKET=REPLACE_WITH_YOUR_S3_BUCKET_NAME
# AWS_S3_ENDPOINT — only set this for LOCAL DEV (LocalStack). OMIT entirely in production.
# AWS_S3_ENDPOINT=http://localstack:4566

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── SMTP (email notifications) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── CIBIL / Tenacio CRIF ─────────────────────────────────────────────────────
TENACIO_CRIF_URL=https://api.tenacio.io/api/v1/services/crif-soft-pull
TENACIO_CRIF_CLIENT_ID=REPLACE_WITH_TENACIO_CLIENT_ID
TENACIO_CRIF_API_KEY=REPLACE_WITH_TENACIO_API_KEY
TENACIO_CRIF_WORKFLOW_ID=REPLACE_WITH_TENACIO_WORKFLOW_ID
