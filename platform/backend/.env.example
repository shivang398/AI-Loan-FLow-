# Server
PORT=8080
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# MySQL databases (one per service domain)
AUTH_DATABASE_URL="mysql://root:password@localhost:3307/platform_auth"
LOAN_DATABASE_URL="mysql://root:password@localhost:3307/platform_loan_core"
CUSTOMER_DATABASE_URL="mysql://root:password@localhost:3307/platform_customer_docs"
SALESOPS_DATABASE_URL="mysql://root:password@localhost:3307/platform_sales_ops"
COMMS_DATABASE_URL="mysql://root:password@localhost:3307/platform_communications"
ANALYTICS_DATABASE_URL="mysql://root:password@localhost:3307/platform_analytics_reporting"

# Redis (JWT revocation)
REDIS_HOST=localhost
REDIS_PORT=6381

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5673
RABBITMQ_EXCHANGE=platform.exchange

# AWS S3 / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=platform-documents
AWS_S3_ENDPOINT=http://localhost:4566

# WhatsApp (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# SMTP (optional notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# CIBIL / Tenacio
TENACIO_CRIF_URL=https://api.tenacio.io/api/v1/services/crif-soft-pull
