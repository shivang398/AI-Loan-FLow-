generator client {
  provider      = "prisma-client-js"
  output        = "../../src/generated/prisma-communications"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("COMMS_DATABASE_URL")
}

model Conversation {
  id                 String                  @id @db.Char(36)
  connectorId        String?                 @map("connector_id") @db.Char(36)
  rmId               String?                 @map("rm_id") @db.Char(36)
  loanApplicationId  String?                 @map("loan_application_id") @db.Char(36)
  assignedOpsUserId  String?                 @map("assigned_ops_user_id") @db.Char(36)
  conversationStatus String                  @map("conversation_status") @db.VarChar(50)
  conversationType   String                  @default("EXTERNAL_CONNECTOR_OPS") @map("conversation_type") @db.VarChar(50)
  customerName       String?                 @map("customer_name") @db.VarChar(255)
  customerPhone      String?                 @map("customer_phone") @db.VarChar(20)
  createdAt          DateTime                @map("created_at")
  updatedAt          DateTime                @map("updated_at")
  messages           Message[]
  unreadTracking     UnreadMessageTracking[]

  @@index([connectorId])
  @@index([loanApplicationId])
  @@map("conversations")
}

model Message {
  id                String                  @id @db.Char(36)
  conversationId    String                  @map("conversation_id") @db.Char(36)
  senderType        String                  @map("sender_type") @db.VarChar(50)
  internalSenderId  String?                 @map("internal_sender_id") @db.Char(36)
  messageChannel    String                  @map("message_channel") @db.VarChar(50)
  messageBody       String?                 @map("message_body") @db.Text
  messageType       String                  @map("message_type") @db.VarChar(50)
  deliveryStatus    String                  @map("delivery_status") @db.VarChar(50)
  whatsappMessageId String?                 @map("whatsapp_message_id") @db.VarChar(255)
  traceId           String?                 @map("trace_id") @db.VarChar(255)
  createdAt         DateTime                @map("created_at")
  conversation      Conversation            @relation(fields: [conversationId], references: [id])
  attachments       MessageAttachment[]
  deliveryStatuses  MessageDeliveryStatus[]

  @@index([conversationId])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @db.Char(36)
  messageId String   @map("message_id") @db.Char(36)
  fileName  String   @map("file_name") @db.VarChar(255)
  fileType  String   @map("file_type") @db.VarChar(100)
  s3Key     String   @map("s3_key") @db.VarChar(512)
  fileSize  BigInt   @map("file_size")
  createdAt DateTime @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id])

  @@map("message_attachments")
}

model MessageDeliveryStatus {
  id        String   @id @db.Char(36)
  messageId String   @map("message_id") @db.Char(36)
  status    String   @db.VarChar(50)
  timestamp DateTime
  remarks   String?  @db.Text
  message   Message  @relation(fields: [messageId], references: [id])

  @@map("message_delivery_status")
}

model WhatsappWebhookLog {
  id              String   @id @db.Char(36)
  payload         Json
  processedStatus String   @map("processed_status") @db.VarChar(50)
  errorMessage    String?  @map("error_message") @db.Text
  createdAt       DateTime @map("created_at")

  @@map("whatsapp_webhook_logs")
}

model NotificationTemplate {
  id              String   @id @db.Char(36)
  templateName    String   @unique @map("template_name") @db.VarChar(100)
  channel         String   @db.VarChar(50)
  contentTemplate String   @map("content_template") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @map("created_at")

  @@map("notification_templates")
}

model UnreadMessageTracking {
  userId         String       @map("user_id") @db.Char(36)
  conversationId String       @map("conversation_id") @db.Char(36)
  unreadCount    Int          @default(0) @map("unread_count")
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@id([userId, conversationId])
  @@map("unread_message_tracking")
}

model WebsocketSession {
  id            String    @id @db.VarChar(255)
  userId        String    @map("user_id") @db.Char(36)
  connectedAt   DateTime  @map("connected_at")
  lastHeartbeat DateTime? @map("last_heartbeat")

  @@map("websocket_sessions")
}

model TeamMeetingRoom {
  id        String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  roomKey   String   @unique @map("room_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("team_meeting_rooms")
}

model TeamMeetingMessage {
  id             String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  roomKey        String   @map("room_key") @db.VarChar(255)
  senderId       String   @map("sender_id") @db.VarChar(255)
  senderName     String   @map("sender_name") @db.VarChar(255)
  senderRole     String?  @map("sender_role") @db.VarChar(100)
  senderInitials String?  @map("sender_initials") @db.VarChar(10)
  body           String   @db.Text
  messageType    String   @default("TEXT") @map("message_type") @db.VarChar(50)
  status         String   @default("DELIVERED") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([roomKey])
  @@map("team_meeting_messages")
}

model WhatsappMessageTemplate {
  id               String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  templateName     String   @unique @map("template_name") @db.VarChar(100)
  templateBody     String   @map("template_body") @db.Text
  templateCategory String   @default("UTILITY") @map("template_category") @db.VarChar(50)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("whatsapp_message_templates")
}

model Notification {
  id             String                    @id @db.Char(36)
  recipientId    String                    @map("recipient_id") @db.Char(36)
  channel        String                    @db.VarChar(50)
  type           String                    @db.VarChar(100)
  status         String                    @db.VarChar(50)
  content        String?                   @db.Text
  title          String?                   @db.VarChar(255)
  read           Boolean                   @default(false)
  idempotencyKey String?                   @unique @map("idempotency_key") @db.VarChar(255)
  retryCount     Int                       @default(0) @map("retry_count")
  createdAt      DateTime                  @map("created_at")
  deliveryLogs   NotificationDeliveryLog[]

  @@map("notifications")
}

model NotificationDeliveryLog {
  id               String        @id @db.Char(36)
  notificationId   String?       @map("notification_id") @db.Char(36)
  deliveryStatus   String        @map("delivery_status") @db.VarChar(50)
  providerResponse String?       @map("provider_response") @db.Text
  attemptedAt      DateTime      @map("attempted_at")
  notification     Notification? @relation(fields: [notificationId], references: [id])

  @@map("notification_delivery_logs")
}
