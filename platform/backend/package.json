{
  "name": "financial-platform-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "fuser -k 8080/tcp 2>/dev/null; tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "npm run prisma:generate:auth && npm run prisma:generate:loan && npm run prisma:generate:customer && npm run prisma:generate:salesops && npm run prisma:generate:comms && npm run prisma:generate:analytics",
    "prisma:generate:auth": "prisma generate --schema=prisma/auth/schema.prisma",
    "prisma:generate:loan": "prisma generate --schema=prisma/loan/schema.prisma",
    "prisma:generate:customer": "prisma generate --schema=prisma/customer/schema.prisma",
    "prisma:generate:salesops": "prisma generate --schema=prisma/salesops/schema.prisma",
    "prisma:generate:comms": "prisma generate --schema=prisma/communications/schema.prisma",
    "prisma:generate:analytics": "prisma generate --schema=prisma/analytics/schema.prisma",
    "prisma:migrate:auth": "prisma migrate dev --schema=prisma/auth/schema.prisma",
    "prisma:migrate:loan": "prisma migrate dev --schema=prisma/loan/schema.prisma",
    "prisma:migrate:customer": "prisma migrate dev --schema=prisma/customer/schema.prisma",
    "prisma:migrate:salesops": "prisma migrate dev --schema=prisma/salesops/schema.prisma",
    "prisma:migrate:comms": "prisma migrate dev --schema=prisma/communications/schema.prisma",
    "prisma:migrate:analytics": "prisma migrate dev --schema=prisma/analytics/schema.prisma",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy:auth && npm run prisma:migrate:deploy:loan && npm run prisma:migrate:deploy:customer && npm run prisma:migrate:deploy:salesops && npm run prisma:migrate:deploy:comms && npm run prisma:migrate:deploy:analytics",
    "prisma:migrate:deploy:auth": "prisma migrate deploy --schema=prisma/auth/schema.prisma",
    "prisma:migrate:deploy:loan": "prisma migrate deploy --schema=prisma/loan/schema.prisma",
    "prisma:migrate:deploy:customer": "prisma migrate deploy --schema=prisma/customer/schema.prisma",
    "prisma:migrate:deploy:salesops": "prisma migrate deploy --schema=prisma/salesops/schema.prisma",
    "prisma:migrate:deploy:comms": "prisma migrate deploy --schema=prisma/communications/schema.prisma",
    "prisma:migrate:deploy:analytics": "prisma migrate deploy --schema=prisma/analytics/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.15.0",
    "@types/pdfkit": "^0.17.6",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.15.0",
    "tsx": "^4.15.7",
    "typescript": "^6.0.3"
  }
}
