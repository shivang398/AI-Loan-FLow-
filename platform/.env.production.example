# =============================================================================
# Real Money Platform — PRODUCTION environment template
#
# Copy to:   platform/.env.production    (gitignored — EC2 only, never commit)
# Used by:   docker compose --env-file .env.production -f docker-compose.prod.yml up -d
#
# This is the SINGLE source of truth for production. Every variable the
# backend, frontend, and compose services need lives here. There is no
# second env file loaded in production.
#
# Generate JWT_SECRET:  openssl rand -hex 32
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_VERSION=latest
NODE_ENV=production
PORT=8080
CORS_ORIGIN=https://realmoneygroups.in
DOMAIN=realmoneygroups.in

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── RDS MySQL (full connection URLs — one per Prisma schema) ─────────────────
# Format: mysql://USER:PASS@RDS_ENDPOINT:3306/DATABASE?ssl=true
AUTH_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_auth?ssl=true
LOAN_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_loan_core?ssl=true
CUSTOMER_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_customer_docs?ssl=true
SALESOPS_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_sales_ops?ssl=true
COMMS_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_communications?ssl=true
ANALYTICS_DATABASE_URL=mysql://REPLACE_DB_USER:REPLACE_DB_PASS@REPLACE_RDS_HOST:3306/platform_analytics_reporting?ssl=true

# ── Redis (Docker-internal — do not change the hostname) ─────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# RABBITMQ_USER / RABBITMQ_PASS also configure the RabbitMQ container itself
RABBITMQ_USER=REPLACE_RABBITMQ_USER
RABBITMQ_PASS=REPLACE_RABBITMQ_PASS
# rabbitmq = Docker-internal service name — do not change the hostname
RABBITMQ_URL=amqp://REPLACE_RABBITMQ_USER:REPLACE_RABBITMQ_PASS@rabbitmq:5672
RABBITMQ_EXCHANGE=platform.exchange

# ── AWS S3 ───────────────────────────────────────────────────────────────────
# IAM user needs only: s3:PutObject, s3:GetObject, s3:DeleteObject on this bucket
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_IAM_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_IAM_SECRET_KEY
AWS_S3_BUCKET=realmoney-document-personal-loan
# Leave blank in production — only LocalStack (local dev) uses an endpoint override
AWS_S3_ENDPOINT=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── SMTP (email notifications) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── CIBIL / Tenacio CRIF ─────────────────────────────────────────────────────
TENACIO_CRIF_URL=https://api.tenacio.io/api/v1/services/crif-soft-pull
TENACIO_CRIF_CLIENT_ID=REPLACE_TENACIO_CLIENT_ID
TENACIO_CRIF_API_KEY=REPLACE_TENACIO_API_KEY
TENACIO_CRIF_WORKFLOW_ID=REPLACE_TENACIO_WORKFLOW_ID
