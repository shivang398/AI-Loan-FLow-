# =============================================================================
# Real Money Platform — LOCAL DEVELOPMENT environment template
#
# Copy to:   platform/.env.local         (gitignored)
# Used by:   docker compose --env-file .env.local up -d   (infra services)
#            platform/backend/.env                          (backend native run)
#
# All values below work out of the box with the default docker-compose.yml.
# Do NOT use any of these values in production.
# =============================================================================

# ── Docker Compose infrastructure services ────────────────────────────────────
APP_VERSION=latest
HTTP_PORT=80
MYSQL_ROOT_PASSWORD=password
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Application ──────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT (dev — rotate before production) ─────────────────────────────────────
JWT_SECRET=local-dev-jwt-secret-change-before-production
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── MySQL (Docker container mapped to localhost:3307) ────────────────────────
AUTH_DATABASE_URL=mysql://root:password@localhost:3307/platform_auth
LOAN_DATABASE_URL=mysql://root:password@localhost:3307/platform_loan_core
CUSTOMER_DATABASE_URL=mysql://root:password@localhost:3307/platform_customer_docs
SALESOPS_DATABASE_URL=mysql://root:password@localhost:3307/platform_sales_ops
COMMS_DATABASE_URL=mysql://root:password@localhost:3307/platform_communications
ANALYTICS_DATABASE_URL=mysql://root:password@localhost:3307/platform_analytics_reporting

# ── Redis (Docker container mapped to localhost:6381) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6381

# ── RabbitMQ (Docker container mapped to localhost:5673) ─────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5673
RABBITMQ_EXCHANGE=platform.exchange

# ── AWS S3 via LocalStack (http://localhost:4566) ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=realmoney-document-personal-loan
AWS_S3_ENDPOINT=http://localhost:4566

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── CIBIL / Tenacio CRIF (use sandbox keys for local testing) ────────────────
TENACIO_CRIF_URL=https://api.tenacio.io/api/v1/services/crif-soft-pull
TENACIO_CRIF_CLIENT_ID=
TENACIO_CRIF_API_KEY=
TENACIO_CRIF_WORKFLOW_ID=
