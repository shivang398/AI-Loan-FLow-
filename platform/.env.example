# =============================================================================
# Real Money Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values before running.
#
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control. Add it to .gitignore.
# ROTATE: All credentials in this file must be strong, unique values.
#         The placeholder values below are NOT safe for any environment.
# =============================================================================


# ─── Application ─────────────────────────────────────────────────────────────

# Image tag used when docker compose builds/pulls images.
# Use a git SHA or semver tag in CI (e.g. APP_VERSION=1.4.2).
APP_VERSION=latest

# Host port the Nginx frontend listens on (container always uses 8080 internally).
HTTP_PORT=80

# Allow-list for CORS. In production set this to your exact frontend domain.
# Never use * in production — it disables the same-origin protection.
CORS_ALLOWED_ORIGIN=https://app.realmoney.in


# ─── Database (AWS RDS MySQL) ─────────────────────────────────────────────────
# Required. Services will refuse to start if DB_PASSWORD is empty.

DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=platform_user
DB_PASSWORD=CHANGE_ME_use_a_strong_random_password
# Enable TLS for DB connections. Required in production with AWS RDS.
DB_USE_SSL=true
DB_REQUIRE_SSL=true


# ─── JWT ─────────────────────────────────────────────────────────────────────
# Required. Used by every service to sign and verify tokens.
# Generate: openssl rand -hex 32
# Must be at least 256 bits (64 hex characters) for HS256.

JWT_SECRET=CHANGE_ME_64_hex_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRY_MS=28800000


# ─── RabbitMQ ────────────────────────────────────────────────────────────────
# Required. Never use guest/guest in production.

RABBITMQ_USER=platform
RABBITMQ_PASS=CHANGE_ME_use_a_strong_random_password


# ─── AWS S3 ──────────────────────────────────────────────────────────────────
# Required for customer-document-service and communications-service.
# Create a dedicated IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject
# scoped to your bucket only. Never use root credentials here.

AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=CHANGE_ME_your_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-realmoney-documents-bucket
# Legacy alias still supported by customer-document-service if AWS_S3_BUCKET is unset.
# S3_BUCKET_NAME=your-realmoney-documents-bucket

# Override only if using a non-standard S3 endpoint (e.g. MinIO, LocalStack).
# Leave commented for real AWS S3.
# AWS_S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com


# ─── PII Encryption (AES-256-GCM for PAN / Aadhaar) ──────────────────────────
# Required. Generate with: openssl rand -hex 16 (must be exactly 32 ASCII chars)
# WARNING: If not set, the service will REFUSE TO START.
# Changing this key after data is stored will make existing encrypted records unreadable.
PII_ENCRYPTION_KEY=CHANGE_ME_exactly_32_ascii_chars__


# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Used by communications-service for email notifications.
# Leave empty to disable email sending (service still starts).

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=


# ─── WhatsApp (Meta Business API) ────────────────────────────────────────────
# Used by communications-service for WhatsApp notifications.
# Leave empty to disable WhatsApp sending.

WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=


# ─── CRIF / CIBIL (Tenacio Bureau API) ───────────────────────────────────────
# Used by loan-core-service for soft-pull credit checks via the CIBIL check tool.
# Leave empty to run in demo mode (simulated data, no real bureau call).
# Production endpoint: https://api.tenacio.io/api/v1/services/crif-soft-pull

TENACIO_CRIF_URL=https://api.tenacio.io/api/v1/services/crif-soft-pull
TENACIO_CRIF_CLIENT_ID=
TENACIO_CRIF_API_KEY=
TENACIO_CRIF_WORKFLOW_ID=c001aecc-e992-42d6-a3fe-b55810d21a02


# ─── Observability ───────────────────────────────────────────────────────────
# LOG_LEVEL controls com.financial.* package verbosity: TRACE, DEBUG, INFO, WARN, ERROR.
# Enable Zipkin tracing by setting TRACING_ENABLED=true and a valid ZIPKIN_ENDPOINT.

LOG_LEVEL=INFO
TRACING_ENABLED=false
TRACING_SAMPLE_RATE=0.0
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans


# =============================================================================
# Security checklist before going to production:
#
# [ ] DB_PASSWORD   — random, 32+ chars, not reused from any other system
# [ ] JWT_SECRET    — generated with: openssl rand -hex 32
# [ ] RABBITMQ_PASS — random, 32+ chars
# [ ] AWS_*         — least-privilege IAM user, no console access, no root keys
# [ ] CORS_ALLOWED_ORIGIN — exact domain, never *
# [ ] .env is in .gitignore — confirm with: git check-ignore -v .env
# [ ] PII_ENCRYPTION_KEY — exactly 32 ASCII chars, generated with: openssl rand -hex 16
# [ ] Rotate any credential that was ever committed or logged
# =============================================================================
