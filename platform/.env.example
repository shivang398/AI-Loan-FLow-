# =============================================================================
# Real Money Platform — Docker Compose variables example
# =============================================================================
# Copy this file to .env and fill in values before running docker compose.
# This file is for COMPOSE-LEVEL variables only.
# Application secrets (DB URLs, JWT, AWS, etc.) live in backend/.env
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_VERSION=latest
HTTP_PORT=80

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Never use * in production.
CORS_ORIGIN=https://app.yourdomain.com

# ─── MySQL (self-hosted only — skip if using external RDS) ───────────────────
# Must match the password used in backend/.env DATABASE_URLs
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_random_password

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=platform
RABBITMQ_PASS=CHANGE_ME_strong_random_password
