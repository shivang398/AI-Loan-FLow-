# ─────────────────────────────────────────────────────────────────────────────
# EC2 Production Environment  — copy to .env and fill in your values
# Place this file at:  platform/.env   (same folder as docker-compose.prod.yml)
# ─────────────────────────────────────────────────────────────────────────────

# ── RDS MySQL ──────────────────────────────────────────────────────────────
RDS_HOST=database-1.xxxxxxxx.ap-south-1.rds.amazonaws.com
RDS_USER=ab_real_money_usr
RDS_PASS=YourRDSPasswordHere

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=Admin@123

# ── Frontend public URL ────────────────────────────────────────────────────
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# ── Ports ──────────────────────────────────────────────────────────────────
HTTP_PORT=80
